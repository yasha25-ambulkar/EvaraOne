{
  "name": "evara-one",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install:backend": "cd backend && npm install --production",
    "install:client": "cd client && npm install",
    "build:client": "cd client && npm run build",
    "build": "npm run install:backend && npm run install:client && npm run build:client",
    "start": "cd backend && node --openssl-legacy-provider src/server.js",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd client && npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}