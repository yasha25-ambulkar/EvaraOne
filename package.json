{
  "name": "evara-one",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "install:backend": "cd backend && npm install --production",
    "install:client": "cd client && npm install",
    "build:client": "cd client && npm run build",
    "build": "npm install && cd client && npm install && npm run build && cd ../backend && npm install --production",
    "start": "cd backend && NODE_ENV=production node src/server.js",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd client && npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "driver.js": "^1.4.0"
  }
}
