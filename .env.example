# ══════════════════════════════════════════════════════════════════════════════
# EVARA-TECH IoT SaaS — RAILWAY ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file and set values in your Railway service dashboard.
# Railway injects these as process.env variables — no .env file needed.

# --- SERVER ---
NODE_ENV=production
PORT=3000
# Set to your Railway frontend URL (e.g., https://your-app.railway.app)
ALLOWED_ORIGINS=https://your-app.railway.app

# --- FIREBASE ADMIN SDK (Backend) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_TYPE=service_account

# --- FIREBASE CLIENT SDK (Frontend — VITE_ prefix required) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_URL=/api/v1
VITE_WS_URL=

# --- SECURITY ---
JWT_SECRET=
ENCRYPTION_KEY=

# --- TELEMETRY ---
THINGSPEAK_API_KEY=

# --- MONITORING ---
SENTRY_DSN=

# --- REDIS (Railway provides REDIS_URL automatically if you add Redis) ---
REDIS_URL=
