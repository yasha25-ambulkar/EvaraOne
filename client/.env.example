# ══════════════════════════════════════════════════════════════════════════════
# EVARA-TECH FRONTEND — ENVIRONMENT TEMPLATE
# ══════════════════════════════════════════════════════════════════════════════

# URL to the Backend API (including /api/v1)
VITE_API_URL=http://localhost:5002/api/v1

# WebSocket URL (if different from VITE_API_URL origin)
# If left blank, it will be derived from VITE_API_URL
VITE_WS_URL=http://localhost:5002

# Firebase client config (required for auth / Firestore features)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
